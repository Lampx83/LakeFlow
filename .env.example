HOST_LAKE_PATH=/data/nas/education
QDRANT_PORT=6333
LAKE_ROOT=/data
QDRANT_HOST=localhost
API_BASE_URL=http://localhost:8011
# Docker, Ollama là container khác: nối vào lakeflow-neu-net rồi dùng tên container (thường là ollama):
#   docker network connect lakeflow-neu-net ollama
#   LLM_BASE_URL=http://ollama:11434
# Docker, Ollama đã map 11434 ra host, không nối network: LLM_BASE_URL=http://host.docker.internal:11434
# Backend chạy ngoài Docker: http://127.0.0.1:11434
# Proxy từ xa (vd): https://research.neu.edu.vn/ollama
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=qwen3:8b
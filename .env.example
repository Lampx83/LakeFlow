HOST_LAKE_PATH=/data/nas/education
QDRANT_PORT=6333
LAKE_ROOT=/data
QDRANT_HOST=localhost
API_BASE_URL=http://localhost:8011
# Docker Compose: docker-compose.yml sets LLM_BASE_URL=http://ollama:11434 on lakeflow-backend (overrides this).
# Match if you run backend outside Docker but Ollama in Compose: use host port, e.g. http://localhost:11434
# Remote/proxy: https://research.neu.edu.vn/ollama
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=qwen3:8b
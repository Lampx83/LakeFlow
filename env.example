# ======================
# LakeFlow DATA LAKE CONFIG
# ======================
LAKEFLOW_DATA_PATH=/Users/mac/Library/CloudStorage/SynologyDrive-education
QDRANT_PORT=6333

# For Docker (volume bind mount: host path -> /data in container)
HOST_LAKE_PATH=/path/to/your/data
LAKE_ROOT=/data
QDRANT_HOST=qdrant
API_BASE_URL=http://lakeflow-backend:8011
# Mount description (shown in System Settings): e.g. "Volume lakeflow_data bind from /datalake/research"
#LAKEFLOW_MOUNT_DESCRIPTION=Volume lakeflow_data bind from /datalake/research

# Embedding model (Ollama). Used for step3 pipeline and search/embed API. Change via Pipeline Runner UI for step3.
EMBED_MODEL=qwen3-embedding:8b
# Optional: comma-separated list for embed model dropdown in Pipeline Runner (step3)
#EMBED_MODEL_OPTIONS=qwen3-embedding:8b,nomic-embed-text,mxbai-embed-large,all-minilm

# Not using Docker
#LAKE_ROOT=/Users/mac/Library/CloudStorage/SynologyDrive-education
#QDRANT_HOST=localhost
#API_BASE_URL=http://localhost:8011


